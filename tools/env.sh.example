#!/usr/bin/env bash
# tools/env.sh — lokális path konfiguráció
# Másold: cp tools/env.sh.example tools/env.sh
# Majd töltsd ki a saját path-jaiddal.
# Ez a fájl gitignored — ne commitold.

# A CIC partner repók szülőkönyvtára (ahol a CentralInfraCore szervezet repói élnek)
export CIC_PARTNERS_ROOT="/path/to/CentralInfraCore"

# CIC ökoszisztéma repo-k helyi path-jai
export CIC_RELAY_PATH="${CIC_PARTNERS_ROOT}/CIC-Relay"
export CIC_SCHEMAS_PATH="${CIC_PARTNERS_ROOT}/CIC-Schemas"
export CIC_MCP_PRIVATE="${CIC_PARTNERS_ROOT}/MCPs/private"
export CIC_KB_PATH="${CIC_MCP_PRIVATE}/source/CentralInfraCore/CIC-basic-knowledge"
export CIC_MCP_KB_DATA="${CIC_MCP_PRIVATE}/kb_data/pkl"
export CIC_MCP_SERVER="${CIC_MCP_PRIVATE}/mcp-server/server.py"

# cic-factory workdir (általában git rev-parse --show-toplevel adja)
export CIC_WORKDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# MCP konfig — alapértelmezés: a cic-factory szülőkönyvtárában lévő CIC/.mcp.json
# export CIC_MCP_CONFIG="/path/to/CIC/.mcp.json"
